{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironthread.local/schemas/handoff.schema.json",
  "title": "Planner to Elliot Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operation",
    "timestamp",
    "phase",
    "elliot_authorized",
    "scope",
    "context_files",
    "primary_path",
    "backup_path"
  ],
  "properties": {
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "phase": {
      "type": "string",
      "const": "EXPLOITATION"
    },
    "elliot_authorized": {
      "type": "boolean",
      "const": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective",
        "in_scope",
        "out_of_scope",
        "stop_conditions",
        "max_attempts_per_path"
      ],
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "in_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "string",
          "minLength": 1
        },
        "stop_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "max_attempts_per_path": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      }
    },
    "context_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "primary_path": {
      "type": "string",
      "minLength": 1
    },
    "backup_path": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
