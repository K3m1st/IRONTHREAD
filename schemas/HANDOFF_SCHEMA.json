{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironthread.local/schemas/handoff.schema.json",
  "title": "Oracle to Elliot Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operation",
    "timestamp",
    "phase",
    "elliot_authorized",
    "scope",
    "context_files",
    "primary_path",
    "backup_path",
    "vulnerability_primitive"
  ],
  "properties": {
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "phase": {
      "type": "string",
      "const": "EXPLOITATION"
    },
    "elliot_authorized": {
      "type": "boolean",
      "const": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective",
        "in_scope",
        "out_of_scope",
        "stop_conditions",
        "max_attempts_per_path",
        "max_turns"
      ],
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "in_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "string",
          "minLength": 1
        },
        "stop_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "max_attempts_per_path": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "max_turns": {
          "type": "integer",
          "minimum": 5,
          "maximum": 40,
          "description": "Total turn budget for this deployment. Oracle sets based on CVE complexity. ELLIOT hard-stops when exhausted."
        }
      }
    },
    "context_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "primary_path": {
      "type": "string",
      "minLength": 1
    },
    "backup_path": {
      "type": "string",
      "minLength": 1
    },
    "vulnerability_primitive": {
      "type": "object",
      "required": ["primitive", "delivery_forms"],
      "properties": {
        "primitive": {
          "type": "string",
          "minLength": 1,
          "description": "What the attacker controls — the underlying input that enables the vulnerability"
        },
        "delivery_forms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "ALL valid forms of the controlled input, not just what PoCs show"
        },
        "defenses_observed": {
          "type": "string",
          "description": "What filtering or defenses the target applies to this input"
        },
        "untested_forms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Delivery forms not yet attempted — ELLIOT should prioritize these"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
