{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironthread.local/schemas/deployment-webdig.schema.json",
  "title": "Planner to WEBDIG Deployment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operation",
    "timestamp",
    "authorized",
    "target",
    "ports",
    "objective",
    "priority_paths",
    "allowed_actions",
    "disallowed_actions",
    "completion_criteria",
    "return_conditions",
    "source_report"
  ],
  "properties": {
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "authorized": {
      "type": "boolean",
      "const": true
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "ports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      }
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "priority_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disallowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "completion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "return_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_report": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
