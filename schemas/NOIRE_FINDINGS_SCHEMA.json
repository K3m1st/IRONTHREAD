{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironthread.local/schemas/noire-findings.schema.json",
  "title": "Noire Findings",
  "$comment": "Shared fields (meta, anomalies, tools_executed) documented in BASE_FINDINGS_SCHEMA.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "objective",
    "current_access",
    "system_profile",
    "high_value_findings",
    "privesc_leads",
    "credentials_and_secrets",
    "misconfigurations",
    "anomalies",
    "oracle_flags",
    "tools_executed",
    "evidence_refs"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "target", "date", "agent", "status"],
      "properties": {
        "operation": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "minLength": 1 },
        "agent": { "type": "string", "const": "NOIRE v1.0" },
        "status": { "type": "string", "enum": ["COMPLETE", "PARTIAL"] }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "objective_completed", "completion_notes"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "objective_completed": { "type": "boolean" },
        "completion_notes": { "type": "string" }
      }
    },
    "current_access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user", "privilege_level", "groups"],
      "properties": {
        "user": { "type": "string", "minLength": 1 },
        "privilege_level": { "type": "string", "minLength": 1 },
        "groups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "shell_quality": { "type": "string" }
      }
    },
    "system_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostname", "os", "kernel"],
      "properties": {
        "hostname": { "type": "string", "minLength": 1 },
        "os": { "type": "string", "minLength": 1 },
        "kernel": { "type": "string", "minLength": 1 },
        "containerization": { "type": "string" }
      }
    },
    "high_value_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "summary", "confidence", "evidence"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "confidence": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "privesc_leads": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "path", "evidence", "complexity", "confidence"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "path": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "complexity": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
          "confidence": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] }
        }
      }
    },
    "credentials_and_secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "location", "notes"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "location": { "type": "string", "minLength": 1 },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    },
    "misconfigurations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "summary", "evidence"],
        "properties": {
          "category": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "anomalies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "impact"],
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 }
        }
      }
    },
    "oracle_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "action", "rationale"],
        "properties": {
          "priority": { "type": "integer", "minimum": 1 },
          "action": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "tools_executed": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool", "command", "output_file"],
        "properties": {
          "tool": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "output_file": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
